PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=mongodb://127.0.0.1/template-ecommerce

COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Payload Commerce"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_

# TagadaPay API keys
TAGADAPAY_API_KEY=tg_api_
TAGADAPAY_STORE_ID=store_
NEXT_PUBLIC_TAGADAPAY_ENABLED=true

# Bankful direct card processing
BANKFUL_USERNAME=your_username
BANKFUL_PASSWORD=your_password
BANKFUL_SANDBOX=true
NEXT_PUBLIC_BANKFUL_ENABLED=true
