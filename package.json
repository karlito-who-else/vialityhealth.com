    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fallow": "2.73.0",
    "jsdom": "28.0.0",
    "lightningcss": "1.32.0",
    "lint-staged": "^15.2.2",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "playwright": "1.60.0",
