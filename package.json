{
  "name": "vialityhealth.com",
  "version": "1.0.0",
  "description": "Ecommerce template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "analyze": "pnpm next experimental-analyze --output",
    "build:analyze": "ANALYZE=true pnpm build",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" payload generate:importmap && next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap && next dev",
    "dev:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "doctor": "react-doctor",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "format:list-different": "oxfmt --list-different",
    "format": "oxfmt",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint:fix-dangerously": "oxlint --fix-dangerously",
    "lint:fix-suggestions": "oxlint --fix-suggestions",
    "lint:fix": "oxlint --fix",
    "lint": "oxlint",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "packages:manage": "npx taze",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "react-doctor": "react-doctor --full",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "static-analysis:generate-badge": "fallow health --format badge > .github/badges/health.svg",
    "static-analysis:dead-code": "fallow dead-code",
    "static-analysis:dupes": "fallow dupes",
    "static-analysis:health": "fallow health",
    "static-analysis:fix": "fallow fix",
    "static-analysis:fix:dry-run": "fallow fix --dry-run",
    "static-analysis": "fallow",
    "stripe-webhooks": "stripe listen --forward-to localhost:3000/api/payments/stripe/webhooks",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=--no-deprecation playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-ecommerce": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-mcp": "^3.85.0",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.85.0",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-accordion": "1.2.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/react-stripe-js": "^6.5.0",
    "@stripe/stripe-js": "^9.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.1",
    "graphql": "^16.14.0",
    "jsonwebtoken": "9.0.1",
    "lucide-react": "0.563.0",
    "next": "16.2.6",
    "next-safe-action": "^8.5.3",
    "next-themes": "0.4.6",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.4.1",
    "qs-esm": "8.0.1",
    "react": "19.2.6",
    "react-doctor": "0.1.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "sonner": "^2.0.7",
    "stripe": "18.5.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
