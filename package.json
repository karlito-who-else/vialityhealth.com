    "prism-react-renderer": "^2.3.1",
    "qs-esm": "8.0.1",
    "react": "19.2.6",
    "react-doctor": "0.1.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "sonner": "^1.7.2",
    "stripe": "18.5.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
