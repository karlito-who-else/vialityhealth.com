{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "build-config.json",
    "next-env.d.ts",
    "dist/**",
    "src/graphql-bigcommerce.d.ts",
    "src/graphql-statamic.d.ts",
    "src/vibes/**"
  ],
  "sortImports": {
    "groups": [
      ["type-builtin", "builtin"],
      ["type-external", "external"],
      ["type-internal", "internal"],
      ["parent", "sibling", "index"]
    ]
  }
}
